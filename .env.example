# RUNECHAIN local environment — copy to .env and fill in real values.
# .env is gitignored; never commit real secrets. server.js auto-loads .env on `node server.js`.

# --- Google SSO (sign-in flow) ---
# Create an OAuth 2.0 Client ID (type: Web application) at
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must EXACTLY match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# --- Sign-in enforcement ---
# 1 = show the in-game sign-in gate and require SSO + Solana wallet to join.
# 0 (or unset) = legacy device-key-only join; the gate stays hidden.
RUNECHAIN_REQUIRE_IDENTITY=1

# 1 = mark session cookies Secure (only over HTTPS). Leave unset for localhost HTTP.
# RUNECHAIN_SECURE_COOKIES=0

# --- Halving admin ---
# Required to call POST /admin/halving/schedule and GET /admin/halving/status.
# Generate a strong random secret: openssl rand -hex 32
RUNECHAIN_ADMIN_TOKEN=
