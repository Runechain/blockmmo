{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://runechain.dev/schemas/engine/events/player-event-schema.json",
  "title": "Runechain Player Event",
  "description": "Canonical client-to-host/server event envelope for player-authored gameplay events. Events may describe local gameplay progress, but ledger, rewards, PvP outcomes, death, and account state remain server-authoritative.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "eventId",
    "type",
    "occurredAt",
    "player",
    "source"
  ],
  "properties": {
    "schemaVersion": {
      "description": "Major schema version for routing and compatibility checks.",
      "const": "1.0.0"
    },
    "eventId": {
      "description": "Unique event id generated by the event producer. UUID v4 is preferred.",
      "type": "string",
      "minLength": 8,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "idempotencyKey": {
      "description": "Optional stable key for deduplicating retries of the same logical event.",
      "type": "string",
      "minLength": 8,
      "maxLength": 160,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "type": {
      "description": "Event family and action. Keep new values namespaced as noun.verb.",
      "type": "string",
      "enum": [
        "player.spawned",
        "player.moved",
        "player.damaged",
        "player.healed",
        "player.died",
        "player.respawned",
        "player.interacted",
        "player.item_collected",
        "player.relic_forged",
        "player.stat_leveled",
        "combat.attack",
        "combat.creature_defeated",
        "quest.progressed",
        "quest.completed",
        "segment.entered",
        "segment.exited",
        "segment.completed",
        "boss.triggered",
        "boss.defeated",
        "pvp.challenge_created",
        "pvp.challenge_accepted",
        "pvp.turn_submitted",
        "pvp.result_received",
        "economy.rune_mined",
        "economy.rune_spent",
        "economy.gold_spent",
        "cosmetic.equipped",
        "ending.chosen"
      ]
    },
    "occurredAt": {
      "description": "Client-observed event time as an RFC 3339 timestamp.",
      "type": "string",
      "format": "date-time"
    },
    "sequence": {
      "description": "Monotonic per-player sequence number assigned by the producer.",
      "type": "integer",
      "minimum": 0
    },
    "player": {
      "$ref": "#/$defs/playerRef"
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "position": {
      "$ref": "#/$defs/position"
    },
    "state": {
      "$ref": "#/$defs/playerState"
    },
    "payload": {
      "$ref": "#/$defs/payload"
    },
    "metadata": {
      "description": "Non-authoritative diagnostics. Must not be required for gameplay decisions.",
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "null"
        ]
      },
      "maxProperties": 24
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "player.moved"
          }
        }
      },
      "then": {
        "required": [
          "position"
        ],
        "properties": {
          "payload": {
            "$ref": "#/$defs/movementPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": [
              "player.damaged",
              "player.healed"
            ]
          }
        }
      },
      "then": {
        "required": [
          "payload"
        ],
        "properties": {
          "payload": {
            "$ref": "#/$defs/vitalsPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "player.interacted"
          }
        }
      },
      "then": {
        "required": [
          "payload"
        ],
        "properties": {
          "payload": {
            "$ref": "#/$defs/interactionPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": [
              "combat.attack",
              "combat.creature_defeated"
            ]
          }
        }
      },
      "then": {
        "required": [
          "payload"
        ],
        "properties": {
          "payload": {
            "$ref": "#/$defs/combatPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": [
              "quest.progressed",
              "quest.completed"
            ]
          }
        }
      },
      "then": {
        "required": [
          "payload"
        ],
        "properties": {
          "payload": {
            "$ref": "#/$defs/questPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": [
              "segment.entered",
              "segment.exited",
              "segment.completed",
              "boss.triggered",
              "boss.defeated"
            ]
          }
        }
      },
      "then": {
        "required": [
          "payload"
        ],
        "properties": {
          "payload": {
            "$ref": "#/$defs/segmentPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": [
              "pvp.challenge_created",
              "pvp.challenge_accepted",
              "pvp.turn_submitted",
              "pvp.result_received"
            ]
          }
        }
      },
      "then": {
        "required": [
          "payload"
        ],
        "properties": {
          "payload": {
            "$ref": "#/$defs/pvpPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": [
              "economy.rune_mined",
              "economy.rune_spent",
              "economy.gold_spent"
            ]
          }
        }
      },
      "then": {
        "required": [
          "payload"
        ],
        "properties": {
          "payload": {
            "$ref": "#/$defs/economyPayload"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "enum": [
              "player.relic_forged",
              "player.stat_leveled",
              "cosmetic.equipped",
              "ending.chosen"
            ]
          }
        }
      },
      "then": {
        "required": [
          "payload"
        ],
        "properties": {
          "payload": {
            "$ref": "#/$defs/progressionPayload"
          }
        }
      }
    }
  ],
  "$defs": {
    "playerRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "description": "Stable local or server-canonical player id.",
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "accountId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "characterId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 48
        },
        "peerId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "town",
            "interior",
            "platformer",
            "battlefield",
            "turnbased",
            "sequencer",
            "server"
          ]
        },
        "areaId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "questId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "stepId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "segmentId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "encounterId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "sessionId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        }
      }
    },
    "position": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "z": {
          "type": "number"
        },
        "vx": {
          "type": "number"
        },
        "vy": {
          "type": "number"
        },
        "dirX": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "dirY": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "moving": {
          "type": "boolean"
        }
      }
    },
    "playerState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hp": {
          "type": "number",
          "minimum": 0
        },
        "maxHp": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "stamina": {
          "type": "number",
          "minimum": 0
        },
        "maxStamina": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "level": {
          "type": "integer",
          "minimum": 1
        },
        "dead": {
          "type": "boolean"
        },
        "skin": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        }
      }
    },
    "payload": {
      "description": "Event-specific data. The schema narrows this object for known event families.",
      "type": "object",
      "additionalProperties": true,
      "maxProperties": 64
    },
    "movementPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "input": {
          "type": "string",
          "enum": [
            "keyboard",
            "mouse",
            "gamepad",
            "touch",
            "network",
            "script"
          ]
        },
        "dash": {
          "type": "boolean"
        }
      }
    },
    "vitalsPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amount"
      ],
      "properties": {
        "amount": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "sourceId": {
          "type": "string",
          "maxLength": 128
        },
        "sourceType": {
          "type": "string",
          "maxLength": 96
        },
        "reason": {
          "type": "string",
          "maxLength": 128
        }
      }
    },
    "interactionPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetId"
      ],
      "properties": {
        "targetId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "targetType": {
          "type": "string",
          "maxLength": 96
        },
        "count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "combatPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attackId": {
          "type": "string",
          "maxLength": 96
        },
        "targetId": {
          "type": "string",
          "maxLength": 128
        },
        "targetType": {
          "type": "string",
          "maxLength": 96
        },
        "damage": {
          "type": "number",
          "minimum": 0
        },
        "weaponId": {
          "type": "string",
          "maxLength": 96
        },
        "rewardRune": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "questPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "questId"
      ],
      "properties": {
        "questId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "stepId": {
          "type": "string",
          "maxLength": 96
        },
        "event": {
          "type": "string",
          "enum": [
            "kill",
            "interact",
            "forge",
            "greatRune",
            "ending",
            "boss",
            "cleared",
            "duel",
            "exit"
          ]
        },
        "target": {
          "type": "string",
          "maxLength": 128
        },
        "monster": {
          "type": "string",
          "maxLength": 96
        },
        "count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "segmentPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "segmentId": {
          "type": "string",
          "maxLength": 96
        },
        "mode": {
          "type": "string",
          "enum": [
            "platformer",
            "battlefield",
            "turnbased"
          ]
        },
        "event": {
          "type": "string",
          "enum": [
            "boss",
            "exit",
            "cleared",
            "duel"
          ]
        },
        "bossId": {
          "type": "string",
          "maxLength": 96
        },
        "result": {
          "type": "string",
          "enum": [
            "entered",
            "completed",
            "won",
            "lost",
            "forfeit",
            "timeout"
          ]
        }
      }
    },
    "pvpPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "duelId"
      ],
      "properties": {
        "duelId": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "opponentPeerId": {
          "type": "string",
          "maxLength": 128
        },
        "turn": {
          "type": "integer",
          "minimum": 0
        },
        "action": {
          "type": "string",
          "enum": [
            "strike",
            "guard",
            "focus",
            "flee"
          ]
        },
        "result": {
          "type": "string",
          "enum": [
            "won",
            "lost",
            "forfeit",
            "timeout"
          ]
        }
      }
    },
    "economyPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "amount"
      ],
      "properties": {
        "currency": {
          "type": "string",
          "enum": [
            "RUNE",
            "GOLD"
          ]
        },
        "amount": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "reason": {
          "type": "string",
          "maxLength": 128
        },
        "transactionId": {
          "type": "string",
          "maxLength": 128
        },
        "blockHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "progressionPayload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "itemId": {
          "type": "string",
          "maxLength": 96
        },
        "relicId": {
          "type": "string",
          "maxLength": 96
        },
        "stat": {
          "type": "string",
          "enum": [
            "vigor",
            "endurance",
            "strength"
          ]
        },
        "oldValue": {
          "type": "number"
        },
        "newValue": {
          "type": "number"
        },
        "skinId": {
          "type": "string",
          "maxLength": 96
        },
        "choice": {
          "type": "string",
          "enum": [
            "A",
            "B",
            "C"
          ]
        }
      }
    }
  }
}
